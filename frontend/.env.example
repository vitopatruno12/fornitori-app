# Copia questo file in .env.development (opzionale) o .env.production e adatta i valori.
#
# Sviluppo locale: lasciare vuoto o usare http://localhost:8000
# Build per il web: imposta l’URL pubblico del backend (HTTPS, senza slash finale).
#
# Esempio produzione:
#   VITE_API_BASE_URL=https://api.tuodominio.it
#
VITE_API_BASE_URL=http://localhost:8000
