# Riferimento variabili (non copiare tutto in un solo .env generico).
#
# Sviluppo (solo PC):  frontend/.env.development
#   VITE_API_BASE_URL=http://localhost:8000
#
# Produzione (vite build / Netlify):  frontend/.env.production nel repo
#   VITE_API_BASE_URL=https://fornitori-app.onrender.com
#
# api.js: export const API_BASE_URL = import.meta.env.VITE_API_BASE_URL || 'http://localhost:8000'
