# Copia in backend/.env e compila i valori. Non committare .env con segreti reali.
#
# Database (in cloud usa l’URL che ti dà il provider, es. Neon, Supabase, Railway)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/fornitori_db
#
# Render.com: NON usare localhost. Crea “PostgreSQL” su Render, poi sul Web Service
# aggiungi DATABASE_URL = Internal Database URL (menu Connect del database).
# Start command: uvicorn app.main:app --host 0.0.0.0 --port $PORT
#
# CORS: in produzione elenca l’URL esatto del frontend (Netlify), senza slash finale.
# Esempio (sostituisci con il tuo sito reale da Site settings → Domains):
#   CORS_ORIGINS=https://fornitori-frontend.netlify.app
# Più origini (custom domain + Netlify): separate da virgola, senza spazi.
# In sviluppo: * oppure http://localhost:5173
#
CORS_ORIGINS=*
