# Copia in backend/.env e compila i valori. Non committare .env con segreti reali.
#
# Database (in cloud usa l’URL che ti dà il provider, es. Neon, Supabase, Railway)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/fornitori_db
#
# CORS: in produzione elenca gli URL da cui apri l’app (frontend), separati da virgola.
# Esempio con app su Netlify e stesso dominio custom:
#   CORS_ORIGINS=https://app.tuodominio.it,https://www.tuodominio.it
# In sviluppo puoi lasciare * (default nel codice se variabile assente) oppure:
#   CORS_ORIGINS=http://localhost:5173
#
CORS_ORIGINS=*
